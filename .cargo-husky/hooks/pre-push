#!/usr/bin/env bash
# Installed by cargo-husky. Runs before every `git push`.
# Runs the heavy coverage gate that pre-commit skips.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Some GUIs and `git` invocations launched outside an interactive shell don't
# inherit `~/.cargo/bin`; surface it here so installed cargo subcommands resolve.
export PATH="$HOME/.cargo/bin:$PATH"

red()  { printf '\033[31m%s\033[0m\n' "$*" >&2; }
blue() { printf '\033[34m%s\033[0m\n' "$*"; }

if ! command -v cargo-llvm-cov >/dev/null 2>&1; then
    red "pre-push: 'cargo-llvm-cov' not found on PATH"
    red "  install:  cargo install cargo-llvm-cov --locked"
    exit 1
fi

LINUX_TARGET="x86_64-unknown-linux-gnu"

yellow() { printf '\033[33m%s\033[0m\n' "$*"; }

blue "[pre-push 1/2] cargo clippy (linux target, cross-platform sanity)"
if ! command -v rustup >/dev/null 2>&1; then
    red "pre-push: rustup not on PATH (Homebrew Rust ships only host target)"
    red "  install: https://rustup.rs"
    exit 1
fi
if ! rustup target list --installed | grep -q "^$LINUX_TARGET\$"; then
    red "pre-push: target $LINUX_TARGET not installed"
    red "  install: rustup target add $LINUX_TARGET"
    exit 1
fi
if command -v x86_64-linux-gnu-gcc >/dev/null 2>&1; then
    RUSTUP_BIN="$(dirname "$(rustup which cargo)")"
    PATH="$RUSTUP_BIN:$PATH" \
        CARGO_TARGET_DIR=target/cross-linux \
        CC_x86_64_unknown_linux_gnu=x86_64-linux-gnu-gcc \
        CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=x86_64-linux-gnu-gcc \
        cargo clippy --all-targets --all-features --target "$LINUX_TARGET" -- \
            -D warnings -W clippy::pedantic -W clippy::nursery
else
    yellow "pre-push: skipping linux clippy — x86_64-linux-gnu-gcc missing"
    yellow "  install (one-time): brew tap messense/macos-cross-toolchains && \\"
    yellow "                     brew install x86_64-unknown-linux-gnu"
    yellow "  CI will still catch non-macOS warnings."
fi

blue "[pre-push 2/2] cargo llvm-cov (gate >=95%)"
# Делегирует Makefile, чтобы он сам разобрался с rustup vs Homebrew LLVM.
make coverage-gate
